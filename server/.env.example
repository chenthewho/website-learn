# ===== 课程学习平台 · 后端环境变量示例 =====
# 使用方式：cp .env.example .env，然后按下方提示替换“改我 / 请替换”的值。
# 重要：JWT_SECRET 与 CONTENT_MASTER_KEY 没有安全默认值，缺失或非法时服务启动会直接报错。

# 服务监听端口
PORT=4000

# 运行环境：development / production
NODE_ENV=development

# 允许跨域的前端来源（Vite 开发服务器）
CORS_ORIGIN=http://localhost:5173

# ===== MySQL 连接 =====
# 需与 docker-compose 中的 MySQL root 密码、库名保持一致
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=course_pw
DB_NAME=course_learn
# 连接池上限（可选，默认 10）
DB_CONNECTION_LIMIT=10

# ===== 安全密钥（务必替换为随机值）=====
# JWT 签名密钥：请替换为足够长的随机字符串
JWT_SECRET=change-me-to-a-long-random-secret-改我

# 内容主密钥：必须是 64 位十六进制（即 32 字节）。下面仅为占位示例，请替换为随机值。
# 生成示例：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONTENT_MASTER_KEY=a1b2c3d4e5f60718293a4b5c6d7e8f90a1b2c3d4e5f60718293a4b5c6d7e8f90

# ===== 课程内容目录 =====
# 导入脚本（npm run import）直接读取此目录；不要把课程内容复制进本仓库。
CONTENT_DIR=/Users/thewho/code/project/ai-agent-learn/docs
