{
  "name": "website-learn-server",
  "version": "1.0.0",
  "private": true,
  "description": "课程学习平台后端服务（Express + MySQL，TypeScript / CommonJS / tsx）",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server/src/index.js",
    "typecheck": "tsc --noEmit",
    "import": "tsx src/scripts/importContent.ts",
    "gen-codes": "tsx src/scripts/gen-codes.ts",
    "list-users": "tsx src/scripts/list-users.ts",
    "grant-access": "tsx src/scripts/grant-access.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4",
    "cors": "^2.8",
    "dotenv": "^16.4",
    "express": "^4.19",
    "express-rate-limit": "^7.4",
    "helmet": "^7.1",
    "jsonwebtoken": "^9.0",
    "morgan": "^1.10",
    "mysql2": "^3.11",
    "nanoid": "^3.3.7",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4",
    "@types/cors": "^2.8",
    "@types/express": "^4.17",
    "@types/jsonwebtoken": "^9.0",
    "@types/morgan": "^1.9",
    "@types/node": "^20",
    "tsx": "^4.16",
    "typescript": "^5.5"
  }
}
