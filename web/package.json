{
  "name": "@website-learn/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "前端：Vite + React 18 + TypeScript。付费课程展示/阅读站（模仿 socratopia 风格）。开发期通过 vite 代理 /api → http://localhost:4000。",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "clsx": "^2.1",
    "highlight.js": "^11.10",
    "mermaid": "^11",
    "react": "^18.3",
    "react-dom": "^18.3",
    "react-markdown": "^9.0",
    "react-router-dom": "^6.26",
    "rehype-highlight": "^7.0",
    "rehype-slug": "^6.0",
    "remark-gfm": "^4.0"
  },
  "devDependencies": {
    "@types/react": "^18.3",
    "@types/react-dom": "^18.3",
    "@vitejs/plugin-react": "^4.3",
    "typescript": "^5.5",
    "vite": "^5.4"
  }
}
